// Table Seven v5 — the shared "cage" data model.
// Game-agnostic: every game logs its money movements and per-round results
// against these tables via a `game` string, so adding a game touches no schema.
//
// Local dev uses SQLite (zero setup, fully verifiable). Production flips the
// provider to postgresql and points DATABASE_URL at Railway Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A player's cage account — the one identity across all games.
model Account {
  token        String        @id // secret, lives in the browser
  playerNo     String        @unique // human-friendly login id
  pin          String
  name         String        @default("")
  cash         Float         @default(1000) // chips in the cage (not on a table)
  comps        Int           @default(0) // times bailed out when broke
  compPoints   Float         @default(0) // earned from wagering → tier
  createdAt    DateTime      @default(now())
  lastSeen     DateTime      @default(now())
  transactions Transaction[]
  rounds       Round[]
}

/// Every money movement: buyin, cashout, rebuy, admin_credit, admin_dock, comp, win, loss.
model Transaction {
  id           Int      @id @default(autoincrement())
  account      Account  @relation(fields: [accountToken], references: [token], onDelete: Cascade)
  accountToken String
  game         String? // "blackjack" | "poker" | ... | null for cage-only moves
  type         String
  amount       Float
  balanceAfter Float
  tableCode    String?
  note         String?
  createdAt    DateTime @default(now())

  @@index([accountToken, createdAt])
}

/// One played round of any game (a blackjack hand, a poker pot, a keno draw…).
model Round {
  id           Int      @id @default(autoincrement())
  account      Account  @relation(fields: [accountToken], references: [token], onDelete: Cascade)
  accountToken String
  game         String
  tableCode    String?
  ref          String? // game round number / hand id
  bet          Float
  result       String
  payout       Float
  createdAt    DateTime @default(now())

  @@index([accountToken, createdAt])
}

/// Staff admins (the owner master key lives in an env var, not here).
model Admin {
  username  String   @id
  hash      String
  salt      String
  createdAt DateTime @default(now())
}
